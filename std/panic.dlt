# panic.dlt — Runtime helper for the `panic("msg")` keyword.
#
# The compiler lowers `panic("msg")` to a call to `dolet_panic(msg)`
# where msg already carries the `[panic at FILE:LINE]` prefix that
# was injected at codegen time. This helper just prints + exits 101.

fun dolet_panic(msg: str):
    print(msg)
    Process.exit(101)
