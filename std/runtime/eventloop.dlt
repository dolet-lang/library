    # Unregister a socket from write notifications
    fun unregister_io_write(self, socket: i64):
        if self.io_poller_ptr == 0:
            return
        # In actual implementation:
        # io_poller: IOPoller = self.io_poller_ptr as IOPoller
        # io_poller.unregister_write(socket)
        x: i32 = 0  # Placeholder
    
    # Poll all tasks in the ready queue
    # Handles task completion and errors without crashing the loop
    fun poll_ready_tasks(self):
        # Process ready tasks one at a time
        # In a real implementation, this would iterate through
        # the ready queue and poll each task's future
        
        if self.ready_count > 0:
            # Poll the next ready task
            # The task's poll() method returns:
            # 0 = Pending (task yielded, will be woken later)
            # 1 = Ready (task completed successfully)
            # 2 = Error (task failed)
            
            # Simulate polling - decrement ready count
            self.ready_count = self.ready_count - 1
            
            # For completed tasks, decrement task count
            # In real implementation, we'd check poll result
            self.task_count = self.task_count - 1
    
    # Poll a single task and handle its result
    # Returns: true if task completed, false if still pending
    fun poll_single_task(self, task_id: i64) -> bool:
        # Remove from ready queue while polling
        self.remove_from_ready_queue(task_id)
        
        # Poll the task's future
        # In real implementation, this would call future.poll(waker)
        # and handle the result
        
        # Simulate completion for now
        return true
    
    # Handle a task that completed successfully
    fun handle_task_completion(self, task_id: i64, result: i64):
        # Task completed - remove from active tasks
        self.task_count = self.task_count - 1
    
    # Handle a task that failed with an error
    # This ensures the event loop continues running other tasks
    fun handle_task_error(self, task_id: i64, error_msg: str):
        # Task failed - remove from active tasks but don't crash
        # Other tasks continue to run (Requirement 3.5)
        self.task_count = self.task_count - 1
    
    # Run until a specific future completes
    fun run_until_complete(self, future_ptr: i64) -> i64:
        # Spawn the future as a task
        handle: JoinHandle<i64> = self.spawn(future_ptr)
        
        # Run the event loop
        self.run()
        
        # Return result (placeholder)
        return 0
    
    # Check if the event loop is currently running
    fun is_running(self) -> bool:
        return self.running
    
    # Get the number of active tasks
    fun get_task_count(self) -> i32:
        return self.task_count
    
    # Get the number of ready tasks
    fun get_ready_count(self) -> i32:
        return self.ready_count

