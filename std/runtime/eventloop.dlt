    # Unregister a socket from read notifications
    fun unregister_io_read(self, socket: i64):
        if self.io_poller_ptr == 0:
            return
        # In actual implementation:
        # io_poller: IOPoller = self.io_poller_ptr as IOPoller
        # io_poller.unregister_read(socket)
